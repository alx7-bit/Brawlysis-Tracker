{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/official/:path*",
      "destination": "https://bsproxy.royaleapi.dev/v1/:path*"
    },
    {
      "source": "/api/brawlers",
      "destination": "https://api.brawlapi.com/v1/brawlers"
    },
    {
      "source": "/api/maps",
      "destination": "https://api.brawlapi.com/v1/maps"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, HEAD, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Content-Type" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ]
}
